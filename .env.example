# Base app URL
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
APP_URL=http://127.0.0.1:3000

# OpenAI (optional)
# If omitted, the app falls back to local structured reading generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Supabase (optional)
# Required only if you want server-side reading persistence and payment/webhook state sync.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Creem payment integration (optional)
# Required only if you want hosted checkout + webhook-based auto unlock.
CREEM_API_KEY=
CREEM_PRODUCT_ID=
CREEM_WEBHOOK_SECRET=

# Product display config
NEXT_PUBLIC_UNLOCK_PRODUCT_LABEL=Tarot 完整解读解锁
NEXT_PUBLIC_UNLOCK_PRICE_CENTS=299
NEXT_PUBLIC_UNLOCK_CURRENCY=USD
